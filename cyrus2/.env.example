# Cyrus 2.0 — Environment Variable Configuration
#
# Copy this file to .env and uncomment / edit the values you want to change.
# All variables have sensible defaults built in; you only need to set the ones
# you want to override.
#
# Usage (bash):
#   export $(grep -v '^#' .env | xargs)
#
# Usage (Windows PowerShell):
#   Get-Content .env | Where-Object { $_ -notmatch '^#' -and $_ } | ForEach-Object { $kv = $_ -split '=',2; [System.Environment]::SetEnvironmentVariable($kv[0], $kv[1], 'Process') }

# ── Port assignments ──────────────────────────────────────────────────────────
# Brain TCP server — voice service connects here for IPC
CYRUS_BRAIN_PORT=8766

# Hook TCP server — Claude Code Stop / PreToolUse / PostToolUse hooks
CYRUS_HOOK_PORT=8767

# Mobile WebSocket — streams events to the Cyrus mobile companion app
CYRUS_MOBILE_PORT=8769

# VS Code companion extension — brain connects here to submit text without UIA
CYRUS_COMPANION_PORT=8770

# Standalone server (cyrus_server.py) — remote brain for mobile-only setups
CYRUS_SERVER_PORT=8765

# ── Timeout constants ─────────────────────────────────────────────────────────
# Maximum seconds to wait for TTS synthesis + playback to complete
CYRUS_TTS_TIMEOUT=25.0

# Socket connect/receive timeout (seconds) used by the hook when reaching brain
CYRUS_SOCKET_TIMEOUT=10

# ── VAD (Voice Activity Detection) thresholds ────────────────────────────────
# Silero probability above which a frame is classified as speech (0.0–1.0)
# Lower = more sensitive (more false positives); higher = stricter (may miss quiet speech)
CYRUS_SPEECH_THRESHOLD=0.6

# Milliseconds of consecutive silence required to end an utterance recording
# Increase if utterances are cut off prematurely; decrease for faster response
CYRUS_SILENCE_WINDOW=1500

# Minimum milliseconds of speech required before an utterance is submitted
CYRUS_MIN_SPEECH_DURATION=500

# ── Watcher poll intervals ────────────────────────────────────────────────────
# Seconds between ChatWatcher polls of the Claude Code chat output pane
CYRUS_CHAT_POLL_MS=0.5

# Seconds between PermissionWatcher polls for Claude Code permission dialogs
CYRUS_PERMISSION_POLL_MS=0.3

# ── Miscellaneous ─────────────────────────────────────────────────────────────
# Hard cap on spoken words in a single TTS call (~12 s at 150 wpm)
CYRUS_MAX_SPEECH_WORDS=200
